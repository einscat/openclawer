# ==========================================
# 全局基础配置
# ==========================================
CONTAINER_PREFIX=app                                    # 容器命名前缀，防止多项目名称冲突
TIMEZONE=Asia/Shanghai                                  # 统一全局时区

# 持久化目录规划（Choose storage path on your machine. For all storage systems）
PERSIST_DIR=/persist
SECRETS_BASE_DIR=/persist/secret

# ==========================================
# OpenClaw
# support latest, 2026.3.2
# ==========================================
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw
OPENCLAW_VERSION=latest
OPENCLAW_GATEWAY_TOKEN=9efdf227fc32c2a6a68b2c142c91fdd06388fb218e50270da0fb6ac423c2ed98 # 替换成自己的Token
OPENCLAW_DOMAIN_ENABLE=false
OPENCLAW_ALLOWED_ORIGINS='["http://127.0.0.1:18789","https://127.0.0.1:18789","http://localhost:18789","https://localhost:18789", "https://192.168.1.190", "https://yourdomain.com"]'
#-------------------------------------
# 资源防爆与 JVM 调优
#-------------------------------------
OPENCLAW_MEM_LIMIT=4G
OPENCLAW_CPU_LIMIT=2.0
OPENCLAW_MEM_RESERVATION=1G
